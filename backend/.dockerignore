# Clairo Backend Docker Ignore
# Files and directories to exclude from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.env.local
.env.*.local

# Development
.git/
.gitignore
.github/
*.md
!README.md
docs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
tests/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject

# OS
.DS_Store
Thumbs.db
*.log

# Docker
Dockerfile*
docker-compose*.yml
.docker/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Secrets (should never be in image)
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Alembic (keep migrations, exclude cache)
alembic/__pycache__/

# Misc
*.bak
*.tmp
*.temp
.mypy_cache/
.ruff_cache/
