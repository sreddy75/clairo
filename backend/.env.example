# Clairo Backend Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Application Settings
# =============================================================================

# Application name and version
APP_NAME=Clairo
APP_VERSION=0.1.0

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enables detailed error messages and API docs)
DEBUG=true

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# Full database URL for SQLAlchemy async connection
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://clairo:clairo_dev@localhost:5432/clairo

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Enable SQL query logging (only in development)
DATABASE_ECHO=false

# =============================================================================
# Redis
# =============================================================================

# Redis URL for caching and Celery broker
REDIS_URL=redis://localhost:6379/0

# Maximum connections in pool
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# Pinecone (Vector Database)
# =============================================================================

# Pinecone API key (get from https://app.pinecone.io)
PINECONE_API_KEY=pcsk_xxxxxxxx

# Pinecone index host URL (get from your index page)
# Format: https://your-index-name-xxxxxx.svc.environment.pinecone.io
PINECONE_INDEX_HOST=

# =============================================================================
# Voyage AI (Embeddings for Knowledge Base)
# =============================================================================

# Voyage AI API key (get from https://voyageai.com)
# Required for knowledge base embedding and search
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxx

# Embedding model (voyage-3.5-lite recommended for best accuracy/cost)
VOYAGE_MODEL=voyage-3.5-lite

# Vector dimensions (must match model - 1024 for voyage-3.5-lite)
VOYAGE_DIMENSIONS=1024

# Max texts per embedding request (API limit is 128)
VOYAGE_BATCH_SIZE=128

# =============================================================================
# MinIO (Object Storage)
# =============================================================================

# MinIO connection settings
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=clairo
MINIO_SECRET_KEY=clairo_dev
MINIO_BUCKET=clairo-documents
MINIO_USE_SSL=false

# =============================================================================
# Celery (Background Tasks)
# =============================================================================

# Celery broker and result backend (using Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Default queue name
CELERY_TASK_DEFAULT_QUEUE=clairo-default

# Task time limits (in seconds)
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# =============================================================================
# Security
# =============================================================================

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# JWT Algorithm
JWT_ALGORITHM=HS256

# Access token expiration (in minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (in days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# Allowed methods (comma-separated or *)
CORS_ALLOW_METHODS=*

# Allowed headers (comma-separated or *)
CORS_ALLOW_HEADERS=*

# =============================================================================
# External Services (for production)
# =============================================================================

# Clerk Authentication (optional - for production)
# CLERK_SECRET_KEY=sk_...
# CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic Claude API (for AI features)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for embeddings)
# OPENAI_API_KEY=sk-...

# Resend (for email notifications)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Clairo <noreply@clairo.com.au>

# =============================================================================
# Xero OAuth (for accounting integration)
# =============================================================================

# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=http://localhost:8000/api/v1/integrations/xero/callback

# =============================================================================
# MYOB OAuth (for accounting integration)
# =============================================================================

# MYOB_CLIENT_ID=
# MYOB_CLIENT_SECRET=
# MYOB_REDIRECT_URI=http://localhost:8000/api/v1/integrations/myob/callback

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (production) or console (development)
LOG_FORMAT=console
