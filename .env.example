# Clairo Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Docker Compose Service Ports
# =============================================================================

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=clairo
POSTGRES_PASSWORD=clairo_dev
POSTGRES_DB=clairo

# Redis
REDIS_PORT=6379

# Qdrant Vector Database
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO Object Storage
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=clairo
MINIO_ROOT_PASSWORD=clairo_dev
MINIO_BUCKET=clairo-documents

# Backend API
BACKEND_PORT=8000

# Frontend Dev Server
FRONTEND_PORT=3000

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enables detailed error messages and /docs endpoint)
DEBUG=true

# =============================================================================
# Security
# =============================================================================

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# JWT Token Expiration (in minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# External Services (for production)
# =============================================================================

# Clerk Authentication (optional - for production)
# CLERK_SECRET_KEY=sk_...
# CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic Claude API (for AI features - Layer 3+)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API (for embeddings)
# OPENAI_API_KEY=sk-...

# Resend (for email notifications)
# RESEND_API_KEY=re_...

# Xero OAuth (for accounting integration)
# XERO_CLIENT_ID=...
# XERO_CLIENT_SECRET=...
# XERO_REDIRECT_URI=http://localhost:8000/api/v1/integrations/xero/callback
