# Clairo Frontend Environment Configuration
# Copy this file to .env.local and update values for your environment

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Authentication (Clerk)
# =============================================================================

# Clerk publishable key (required - from Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk secret key (required for middleware - from Clerk dashboard)
CLERK_SECRET_KEY=sk_test_...

# Clerk sign-in/sign-up URLs (these match our route structure)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =============================================================================
# Feature Flags
# =============================================================================

# Enable development features
# NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
