# Clairo Staging Environment Template
# Copy this file and fill in actual values in Railway/Vercel dashboard
# Use test/sandbox API keys where possible

# =============================================================================
# Database (Railway Managed PostgreSQL - Staging)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/clairo_staging

# =============================================================================
# Cache & Queue (Railway Managed Redis - Staging)
# =============================================================================
REDIS_URL=redis://user:password@host:6379

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=staging
DEBUG=true
APP_NAME=Clairo (Staging)
APP_VERSION=1.0.0-staging

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-staging-secret-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=https://staging.clairo.com.au,http://localhost:3000

# =============================================================================
# Authentication (Clerk - Development/Test Keys)
# =============================================================================
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# =============================================================================
# AI/LLM (Anthropic - Same key, but consider rate limits)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Email (Resend - Use test mode or sandbox)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Clairo Staging <staging@clairo.com.au>
RESEND_ENABLED=true

# =============================================================================
# Payment Processing (Stripe - Test Mode)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Stripe Test Price IDs
STRIPE_PRICE_STARTER=price_test_...
STRIPE_PRICE_PROFESSIONAL=price_test_...
STRIPE_PRICE_GROWTH=price_test_...

# =============================================================================
# Integrations
# =============================================================================
# Xero OAuth (Demo Company)
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=https://api-staging.clairo.com.au/api/v1/integrations/xero/callback

# =============================================================================
# Error Tracking (Sentry - Staging Environment)
# =============================================================================
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# =============================================================================
# Vector Database (Pinecone - Staging Index)
# =============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-staging-environment

# =============================================================================
# Embeddings (Voyage AI)
# =============================================================================
VOYAGE_API_KEY=your-voyage-api-key

# =============================================================================
# Object Storage (MinIO/S3 - Staging Bucket)
# =============================================================================
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=your-staging-access-key
MINIO_SECRET_KEY=your-staging-secret-key
MINIO_BUCKET=clairo-staging-documents
MINIO_SECURE=true
