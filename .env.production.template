# Clairo Production Environment Template
# Copy this file and fill in actual values in Railway/Vercel dashboard
# NEVER commit actual secrets to the repository

# =============================================================================
# Database (Railway Managed PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# =============================================================================
# Cache & Queue (Railway Managed Redis)
# =============================================================================
REDIS_URL=redis://user:password@host:6379

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=production
DEBUG=false
APP_NAME=Clairo
APP_VERSION=1.0.0

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-256-bit-secret-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=https://www.clairo.com.au,https://clairo.com.au

# =============================================================================
# Authentication (Clerk)
# =============================================================================
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# =============================================================================
# AI/LLM (Anthropic)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Clairo <noreply@clairo.com.au>
RESEND_ENABLED=true

# =============================================================================
# Payment Processing (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_GROWTH=price_...

# =============================================================================
# Integrations
# =============================================================================
# Xero OAuth
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=https://api.clairo.com.au/api/v1/integrations/xero/callback

# =============================================================================
# Error Tracking (Sentry)
# =============================================================================
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =============================================================================
# Vector Database (Pinecone)
# =============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-environment

# =============================================================================
# Embeddings (Voyage AI)
# =============================================================================
VOYAGE_API_KEY=your-voyage-api-key

# =============================================================================
# Object Storage (MinIO/S3)
# =============================================================================
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=clairo-documents
MINIO_SECURE=true
